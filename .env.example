# Tulip Accounting — example environment file.
#
# Copy to .env (gitignored) and edit. Defaults below are safe placeholders;
# REPLACE secret values before running against a real deployment.
#
# References: docs/QUICKSTART.md, docs/THREAT_MODEL.md, packages/tulip-api/src/tulip_api/config.py.

# ---- Required for any boot ------------------------------------------------

# Field-encryption master key. 32 raw bytes, base64-encoded.
# Generate with: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# In prod (TULIP_ENV=prod), boot refuses if this is unset or ephemeral.
TULIP_MASTER_KEY=REPLACE_ME_BASE64_32_BYTES=

# JWT signing secret. Any sufficiently long random string.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
TULIP_JWT_SECRET=REPLACE_ME_RANDOM_STRING

# SQLite by default. Postgres URL acceptable when Phase 10 lands.
TULIP_DATABASE_URL=sqlite:///./tulip.db

# Directory for encrypted attachment blobs (statement PDFs, receipts, etc.).
TULIP_ATTACHMENT_ROOT=./attachments

# ---- Optional -------------------------------------------------------------

# Environment flag: dev | prod. In prod the boot path refuses ephemeral
# master keys / JWT secrets. Default: dev.
# TULIP_ENV=dev

# Alternative to TULIP_MASTER_KEY: path to a 0600 file containing the
# base64-encoded key. Useful when the key lives in a secret-manager mount.
# TULIP_KEY_FILE=/run/secrets/tulip_master_key

# CLI token-store backend. Default uses the OS keyring; set to a path
# for a JSON-file backend (testing/CI only; do NOT use in production).
# TULIP_TOKEN_STORE=./.tulip-tokens.json

# CLI default API base URL (override per-invocation with --api-url).
# TULIP_API_URL=http://localhost:8000

# ---- AI provider keys (optional, BYOK; see ADR-0005) ---------------------
#
# Per-household AI keys are stored field-encrypted in the DB and surfaced
# via `tulip ai set-key`. The env-var path below is supported for
# deployments that prefer process-env over DB storage.
#
# TULIP_AI_KEY_ANTHROPIC=sk-ant-...
# TULIP_AI_KEY_OPENAI=sk-...
# TULIP_AI_KEY_GOOGLE=...

# Feature flag: register the daily-insights handler with the runner
# (see ADR-0005 §"Daily-insights handler registration"). Default off;
# only set when an operator has decided on cadence + per-user
# scheduling. Off by design in v1.
# TULIP_AI_FORECAST_ENABLED=false
